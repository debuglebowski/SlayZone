<div class="anim-isolated anim-love-terminals">
  <section class="terminal-love-banner" id="deep-banner">
    <canvas id="deep-canvas"></canvas>
    <h2>Let's make the world <span class="love">fall in love</span> with terminals<span class="cursor"></span></h2>
  </section>
</div>

<script is:inline>
// Deep ocean banner — bioluminescent particles + caustic light
(function() {
  var banner = document.getElementById('deep-banner');
  var canvas = document.getElementById('deep-canvas');
  var ctx = canvas.getContext('2d');
  var particles = [];
  var caustics = [];
  var hovering = false;
  var hoverFade = 0; // 0-1
  var raf;
  var W, H;

  function resize() {
    var r = banner.getBoundingClientRect();
    W = canvas.width = r.width;
    H = canvas.height = r.height;
  }

  // Bioluminescent particle
  function makeParticle() {
    var hues = [190, 200, 210, 170, 240]; // cyan-blue range
    var hue = hues[Math.floor(Math.random() * hues.length)];
    return {
      x: Math.random() * W,
      y: Math.random() * H,
      r: Math.random() * 2.5 + 0.5,
      vx: (Math.random() - 0.5) * 0.3,
      vy: -Math.random() * 0.4 - 0.1, // drift upward slowly
      alpha: 0,
      maxAlpha: Math.random() * 0.6 + 0.2,
      pulse: Math.random() * Math.PI * 2,
      pulseSpeed: Math.random() * 0.02 + 0.01,
      hue: hue,
      glowSize: Math.random() * 15 + 8
    };
  }

  // Caustic light patch
  function makeCaustic() {
    return {
      x: Math.random() * W,
      y: Math.random() * H,
      rx: Math.random() * 80 + 40,
      ry: Math.random() * 40 + 20,
      alpha: 0,
      maxAlpha: Math.random() * 0.04 + 0.01,
      phase: Math.random() * Math.PI * 2,
      speed: Math.random() * 0.008 + 0.003,
      drift: Math.random() * 0.2 + 0.05,
      angle: Math.random() * Math.PI
    };
  }

  function init() {
    resize();
    particles = [];
    caustics = [];
    for (var i = 0; i < 50; i++) particles.push(makeParticle());
    for (var j = 0; j < 6; j++) caustics.push(makeCaustic());
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);

    // Fade toward target
    var target = hovering ? 1 : 0;
    hoverFade += (target - hoverFade) * 0.04;

    if (hoverFade < 0.005 && !hovering) {
      hoverFade = 0;
      ctx.clearRect(0, 0, W, H);
      raf = null;
      return;
    }

    // Caustic light patches
    for (var c = 0; c < caustics.length; c++) {
      var cs = caustics[c];
      cs.phase += cs.speed;
      cs.x += cs.drift;
      if (cs.x > W + 100) cs.x = -100;
      var a = (Math.sin(cs.phase) * 0.5 + 0.5) * cs.maxAlpha * hoverFade;
      ctx.save();
      ctx.translate(cs.x, cs.y);
      ctx.rotate(cs.angle);
      ctx.beginPath();
      ctx.ellipse(0, 0, cs.rx, cs.ry, 0, 0, Math.PI * 2);
      ctx.fillStyle = 'rgba(56, 182, 255, ' + a + ')';
      ctx.fill();
      ctx.restore();
    }

    // Particles
    for (var i = 0; i < particles.length; i++) {
      var p = particles[i];
      p.pulse += p.pulseSpeed;
      p.x += p.vx;
      p.y += p.vy;

      // Wrap
      if (p.y < -10) { p.y = H + 10; p.x = Math.random() * W; }
      if (p.x < -10) p.x = W + 10;
      if (p.x > W + 10) p.x = -10;

      var targetAlpha = hovering ? p.maxAlpha : 0;
      p.alpha += (targetAlpha - p.alpha) * 0.03;

      var pulse = Math.sin(p.pulse) * 0.3 + 0.7;
      var a = p.alpha * pulse * hoverFade;

      // Glow
      var grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.glowSize);
      grad.addColorStop(0, 'hsla(' + p.hue + ', 100%, 75%, ' + (a * 0.5) + ')');
      grad.addColorStop(1, 'hsla(' + p.hue + ', 100%, 50%, 0)');
      ctx.fillStyle = grad;
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.glowSize, 0, Math.PI * 2);
      ctx.fill();

      // Core
      ctx.fillStyle = 'hsla(' + p.hue + ', 100%, 85%, ' + a + ')';
      ctx.beginPath();
      ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
      ctx.fill();
    }

    raf = requestAnimationFrame(draw);
  }

  banner.addEventListener('mouseenter', function() { hovering = true; if (!raf) raf = requestAnimationFrame(draw); });
  banner.addEventListener('mouseleave', function() { hovering = false; });
  window.addEventListener('resize', resize);

  init();
})();
</script>
