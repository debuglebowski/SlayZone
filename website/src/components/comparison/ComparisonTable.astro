---
import ComparisonCell from './ComparisonCell.astro'
import InfoTooltip from '../ui/InfoTooltip.astro'

const { competitors, rows } = Astro.props
---

<div class="cg-frame">
  <div class="cg-scroll">
    <table class="cg">
      <thead>
        <tr>
          <th><button class="expand-btn" type="button" data-expand-btn>↔</button></th>
          {competitors.map((name: string, i: number) => (
            <th class={i === 0 ? 'col-slayzone' : ''}>{name}</th>
          ))}
        </tr>
      </thead>
      <tbody>
        {rows.map((row: any) => {
          if (row.spacer) {
            return (
              <tr class="no-border">
                <td style="height: 16px;"></td>
                {competitors.map(() => <td></td>)}
              </tr>
            )
          }
          const rowClass = [
            row.noBorder ? 'no-border' : '',
            row.punchline ? 'punchline' : '',
          ].filter(Boolean).join(' ')
          return (
            <tr class={rowClass}>
              <td>
                <span class="feature-label">
                  {row.feature}
                  {row.tooltip && <InfoTooltip text={row.tooltip} />}
                </span>
              </td>
              {row.values.map((v: string) => (
                <td><ComparisonCell value={v} /></td>
              ))}
            </tr>
          )
        })}
      </tbody>
    </table>
  </div>
</div>

<style>
  .cg-frame { position: relative; }
  .cg-frame::after {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 32px;
    background: linear-gradient(to right, transparent, #fff);
    pointer-events: none;
    z-index: 2;
    transition: opacity 0.3s;
  }
  .cg-frame.scrolled-end::after { opacity: 0; }
  .cg-scroll { overflow-x: auto; }
  .cg-scroll.scrolled th:first-child,
  .cg-scroll.scrolled td:first-child {
    box-shadow: 4px 0 8px -2px rgba(0, 0, 0, 0.06);
  }
  table.cg {
    border-collapse: separate;
    border-spacing: 0;
    font-size: 14px;
  }
  .cg th,
  .cg td {
    padding: 12px 12px;
    text-align: center;
    width: 120px;
    min-width: 120px;
    border-bottom: 1px solid #e0e0e8;
  }
  .cg th:first-child,
  .cg td:first-child {
    text-align: left;
    font-weight: 500;
    white-space: nowrap;
    width: 240px;
    min-width: 240px;
    position: sticky;
    left: 0;
    background: #fff;
    z-index: 1;
  }
  .cg thead th {
    padding: 0 12px 16px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 11px;
    font-weight: 700;
    color: #1a1a2e;
    border-bottom: 2px solid #e0e0e8;
    white-space: nowrap;
  }
  .cg thead .col-slayzone {
    color: var(--accent);
    font-size: 12px;
  }
  .expand-btn {
    background: none;
    border: 1px solid #e0e0e8;
    border-radius: 6px;
    padding: 4px 10px;
    font-family: 'Outfit', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: #888;
    cursor: pointer;
    transition: all 0.2s;
  }
  .expand-btn:hover {
    border-color: #ccc;
    color: #1a1a2e;
  }
  .cg .no-border td { border-bottom: none; }
  .cg .punchline td {
    background: #fef3ed;
    border-bottom: none;
    font-weight: 700;
    font-size: 15px;
    padding: 20px 12px;
  }
  .cg .punchline td:first-child {
    background: #fef3ed;
    border-radius: 12px 0 0 12px;
  }
  .cg .punchline td:last-child { border-radius: 0 12px 12px 0; }
  .feature-label {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  @media (max-width: 640px) {
    .cg th:first-child,
    .cg td:first-child {
      min-width: 160px;
      width: 160px;
      font-size: 13px;
    }
    .cg th,
    .cg td {
      min-width: 80px;
      width: 80px;
      padding: 10px 8px;
    }
    .cg thead th { font-size: 10px; }
    .cg .punchline td { font-size: 13px; padding: 14px 8px; }
    .expand-btn { display: none; }
  }
</style>
