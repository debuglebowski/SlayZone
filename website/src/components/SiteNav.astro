---
import SocialLinks from './SocialLinks.astro'
import { navLinks } from '../data/navLinks'

const { current = '' } = Astro.props
---

<nav class="site-nav">
  <a href="/" class="logo">Slay<span class="slash">/</span>Zone</a>
  <div class="nav-right">
    <ul class="nav-links" aria-label="Primary">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} aria-current={current === link.key ? 'page' : undefined}>{link.label}</a>
        </li>
      ))}
    </ul>
    <div class="social-links" aria-label="Social links">
      <SocialLinks />
    </div>
  </div>
</nav>
