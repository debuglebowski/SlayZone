<div class="anim anim-board">
        <div class="app-frame" style="flex-direction:row;position:relative;">
          <div class="fk-cursor" id="fk-cursor"><svg viewBox="0 0 24 24" fill="none"><path d="M5 3l14 8.5L12 14l-2 7L5 3z" fill="white" stroke="black" stroke-width="1.5" stroke-linejoin="round"/></svg></div>
          <div class="fk-click-ripple" id="fk-ripple"></div>
          <div class="fk-layout">
            <!-- Sidebar -->
            <div class="fk-sidebar">
              <div class="fk-sidebar-dots"><span class="app-dot r"></span><span class="app-dot y"></span><span class="app-dot g"></span></div>
              <div class="fk-proj" id="fk-p-sz" style="background:#4466ff;">SZ<div class="fk-proj-dot" style="background:var(--green)"></div></div>
              <div class="fk-proj active" id="fk-p-wd" style="background:#ee8833;">WD</div>
              <div class="fk-proj" id="fk-p-hc" style="background:#44bb55;">HC</div>
              <div style="width:36px;height:36px;border-radius:10px;border:1px dashed var(--border);display:flex;align-items:center;justify-content:center;color:var(--text-dim);font-size:16px;">+</div>
            </div>
            <!-- Main -->
            <div class="fk-main">
