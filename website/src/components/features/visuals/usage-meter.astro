<script is:inline>
(function() {
  var sleep = window.__feat.sleep;
  var loopOnVisible = window.__feat.loopOnVisible;
  var revealLines = window.__feat.revealLines;
  var resetLines = window.__feat.resetLines;
  loopOnVisible(document.getElementById('feat-11'), async function() {
    var pop = document.getElementById('f11-popover');
    var cursor = document.getElementById('f11-cursor');
    var trigger = document.getElementById('f11-trigger');
    var bars = [
      { el: document.getElementById('f11-claude-5h'), pct: document.getElementById('f11-claude-5h-pct'), target: 72 },
      { el: document.getElementById('f11-claude-7d'), pct: document.getElementById('f11-claude-7d-pct'), target: 38 },
      { el: document.getElementById('f11-codex-5h'), pct: document.getElementById('f11-codex-5h-pct'), target: 45 },
      { el: document.getElementById('f11-codex-7d'), pct: document.getElementById('f11-codex-7d-pct'), target: 21 }
    ];
    // Reset
    var burn = document.getElementById('f11-popover').closest('.feat-burn');
    var w = burn.offsetWidth;
    pop.classList.remove('vis');
    cursor.classList.remove('vis');
    cursor.style.transition = 'none';
    cursor.style.top = '50%'; cursor.style.left = '50%';
    bars.forEach(function(b) { b.el.style.width = '0'; b.pct.textContent = '0%'; });
    await sleep(800);
    // Show cursor in center
    cursor.classList.add('vis');
    await sleep(400);
    // Move cursor to trigger
    cursor.style.transition = '';
    cursor.style.top = '-18px'; cursor.style.left = (w - 90) + 'px';
    await sleep(800);
    // Click — show popover
    pop.classList.add('vis');
    await sleep(600);
    // Animate bars
    bars.forEach(function(b) { b.el.style.width = b.target + '%'; });
    var steps = 15;
    for (var i = 1; i <= steps; i++) {
      var p = i / steps;
      bars.forEach(function(b) { b.pct.textContent = Math.round(b.target * p) + '%'; });
      await sleep(60);
    }
    // Move cursor away
    await sleep(1000);
    cursor.style.top = '40%'; cursor.style.left = '50%';
    await sleep(600);
    cursor.classList.remove('vis');
    await sleep(4000);
    pop.classList.remove('vis');
    await sleep(1200);
  });
})();
</script>
