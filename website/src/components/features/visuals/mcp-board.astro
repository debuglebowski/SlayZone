<script is:inline>
(function() {
  var sleep = window.__feat.sleep;
  var loopOnVisible = window.__feat.loopOnVisible;
  var revealLines = window.__feat.revealLines;
  var resetLines = window.__feat.resetLines;
  loopOnVisible(document.getElementById('feat-16'), async function() {
    var term = document.getElementById('f16-term');
    var termWrap = document.getElementById('f16-term-wrap');
    var board = document.getElementById('f16-board');
    var cards = board.querySelectorAll('.f16-card');
    var cAuth = document.getElementById('f16-c-auth');
    var cRate = document.getElementById('f16-c-rate');

    // Reset: show terminal, hide board, remove clones, restore originals
    termWrap.style.display = ''; board.style.display = 'none';
    board.querySelectorAll('.f16-card:not([id])').forEach(function(c) { c.remove(); });
    cAuth.style.display = ''; cAuth.classList.remove('vis','moving');
    cRate.style.display = ''; cRate.classList.remove('vis','moving');
    cards.forEach(function(c) { c.classList.remove('vis','moving'); });
    resetLines(term);
    await sleep(200);

    // Play terminal lines (fast, no extra padding)
    var lines = term.querySelectorAll('.tl:not(.instant)');
    var maxD = 0;
    lines.forEach(function(l) { var d = parseInt(l.dataset.d) || 0; if (d > maxD) maxD = d; setTimeout(function() { l.classList.add('vis'); }, d); });
    await sleep(maxD + 200);

    // Switch to kanban
    termWrap.style.display = 'none'; board.style.display = '';

    // Cards appear one by one
    for (var i = 0; i < cards.length; i++) {
      cards[i].classList.add('vis');
      await sleep(100);
    }
    await sleep(800);

    // Move Auth refactor: In Progress → Review
    cAuth.classList.add('moving');
    await sleep(350);
    cAuth.style.display = 'none';
    var reviewCol = cRate.parentElement;
    var authClone = cAuth.cloneNode(true);
    authClone.className = 'f16-card';
    authClone.style.display = '';
    authClone.querySelector('.f16-card-meta').textContent = 'review';
    reviewCol.appendChild(authClone);
    await sleep(50);
    authClone.classList.add('vis');
    await sleep(800);

    // Move Rate limiting: Review → Done
    cRate.classList.add('moving');
    await sleep(350);
    cRate.style.display = 'none';
    var doneCol = document.getElementById('f16-c-ci').parentElement;
    var rateClone = cRate.cloneNode(true);
    rateClone.className = 'f16-card';
    rateClone.style.display = '';
    rateClone.querySelector('.f16-card-meta').textContent = 'done · just now';
    doneCol.appendChild(rateClone);
    await sleep(50);
    rateClone.classList.add('vis');
    await sleep(800);
  });
})();
</script>
