<script is:inline>
(function() {
  var sleep = window.__feat.sleep;
  var loopOnVisible = window.__feat.loopOnVisible;
  var revealLines = window.__feat.revealLines;
  var resetLines = window.__feat.resetLines;
  (function() {
    function switchF2Tab(idx) {
      var tabs = document.querySelectorAll('#f2-tabs .tab-item');
      tabs.forEach(function(t) { t.classList.remove('active'); });
      tabs[idx].classList.add('active');
      document.getElementById('f2-view-1').style.display = idx === 1 ? '' : 'none';
      document.getElementById('f2-view-2').style.display = idx === 2 ? '' : 'none';
    }

    loopOnVisible(document.getElementById('feat-2'), async function() {
      // Start on Auth refactor
      switchF2Tab(1);
      var c1 = document.getElementById('f2-term');
      resetLines(c1);
      await sleep(400);
      await revealLines(c1);
      await sleep(1500);

      // Switch to Search endpoint
      switchF2Tab(2);
      var c2 = document.getElementById('f2-term-2');
      resetLines(c2);
      await sleep(400);
      await revealLines(c2);
      await sleep(1500);

      // Switch back to Auth
      switchF2Tab(1);
      await sleep(2000);
    });
  })();
})();
</script>
